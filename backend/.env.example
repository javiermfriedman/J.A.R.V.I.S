# Copy to .env and fill in values (never commit .env).
# Load order: python-dotenv reads from the current working directory when you start uvicorn from backend/.

# Speech / LLM / TTS (required for the voice pipeline)
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
OPENAI_API_KEY=

# Google OAuth — directory containing credentials.json (and writable for token.json).
# Defaults to app/integrations/google/config/ if unset.
# CONFIG_PATH=

# Twilio — reserved for future telephony; not required for the WebRTC + Pipecat path today.
# TWILIO_SID=
# TWILIO_TOKEN=
# TWILIO_NUMBER=
